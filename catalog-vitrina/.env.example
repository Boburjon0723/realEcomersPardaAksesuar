# ============================================================
# CRM bilan bir xil Supabase baza (bir loyiha — bir URL va anon key)
# Olish: Supabase Dashboard → Settings → API
#   - Project URL     → VITE_SUPABASE_URL
#   - anon / public   → VITE_SUPABASE_ANON_KEY
#
# CRM (Next.js) da NEXT_PUBLIC_SUPABASE_* bo‘lsa, qiymatlar bir xil,
# faqat nomi boshida VITE_ (Vite qoidasi).
# ============================================================

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_JWT_HERE

# Saytning ochiq URL (npm run qr:generate uchun). Vercel Production ga ham qo‘ying.
# Misol: https://catalog-acsessuar.vercel.app
VITE_SITE_PUBLIC_URL=

VITE_SITE_NAME=Katalog
VITE_CATALOG_LANG=uz
