{
  "name": "crm-dashboard",
  "version": "1.0.0",
  "description": "Nuur Home CRM Desktop Application",
  "author": "Nuur Home",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "dev:fresh": "npm run dev:clean && next dev -p 4000",
    "dev:poll": "cross-env NEXT_WEBPACK_POLL=1 next dev -p 4000",
    "dev:3000": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "icons:apple": "node scripts/generate-apple-touch.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.97.0",
    "electron-serve": "^1.3.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.263.1",
    "next": "14.2.22",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/react": "19.2.7",
    "autoprefixer": "^10.4.17",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.22",
    "postcss": "^8.4.35",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.nuurhome.crm",
    "productName": "Nuur Home CRM",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    }
  }
}
