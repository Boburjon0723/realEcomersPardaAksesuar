# Vercel da Project Settings > Environment Variables ga qo'shing
#
# Lokal: npm run dev → http://localhost:4000 (package.json da PORT=4000)
#
# Supabase (majburiy)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nuur ERP (Vite) manzili — Buyurtmalar «ERP» tugmasi yangi tabda ochadi (masalan http://localhost:5173)
NEXT_PUBLIC_NUUR_ERP_URL=http://localhost:5173

# Moliya / hamkorlar: hamkor yoki tranzaksiyani o‘chirish uchun parol (NEXT_PUBLIC_ — brauzerda ham bo‘ladi).
# Vercel: Project → Settings → Environment Variables → NEXT_PUBLIC_MOLIYA_DELETE_PIN, keyin redeploy.
# NEXT_PUBLIC_MOLIYA_DELETE_PIN=sizning-mahfiy-parolingiz

# Xodimlar (CRM): tahrir, o‘chirish, saqlash, oylik va avans — faqat shu parol bilan (bot telefon orqali alohida).
# Bo‘sh qoldirsangiz, NEXT_PUBLIC_MOLIYA_DELETE_PIN ishlatiladi (bir parol ikkala joy uchun).
# NEXT_PUBLIC_XODIMLAR_ACTION_PIN=sizning-mahfiy-parolingiz

# Telegram xabarlar uchun (ixtiyoriy)
# NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=
# NEXT_PUBLIC_TELEGRAM_CHAT_ID=

# PWA / service worker (ixtiyoriy). true bo‘lmasa prod da SW yo‘q — deploy yangilanishi tez ko‘rinadi.
# NEXT_PUBLIC_ENABLE_PWA=true

# Statistika sahifasi: AI hisobot. Kalitlar faqat serverda — brauzerga chiqarmang.
#
# OpenRouter (tavsiya): https://openrouter.ai/keys — OPENROUTER_API_KEY. U bo‘lsa, Gemini kalitidan ustun ishlatiladi.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_HTTP_REFERER=https://sizning-domen.vercel.app
#
# Google Gemini (zaxira): https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
