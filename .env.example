# Vercel da Project Settings > Environment Variables ga qo'shing
# Saytning to'liq prod URL — ulashish localhost emas bo'lishi uchun (Vercel: Production env ga qo'shing)
# Misol: https://nuur-home-collection.vercel.app yoki o'z domeningiz (https://nuurhome.uz)
# REACT_APP_SITE_URL=https://nuur-home-collection.vercel.app

# Supabase (majburiy)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Admin emails (ixtiyoriy)
REACT_APP_ADMIN_EMAILS=admin@example.com

# To'lov integratsiyalari (ixtiyoriy — bo'sh qoldirilsa to'lov tugmalari ishlamasligi mumkin)
# REACT_APP_CLICK_MERCHANT_ID=
# REACT_APP_CLICK_SERVICE_ID=
# REACT_APP_CLICK_SECRET_KEY=
# REACT_APP_UZCARD_TERMINAL_ID=
# REACT_APP_UZCARD_API_KEY=
# REACT_APP_PAYME_MERCHANT_ID=
# REACT_APP_PAYME_TEST_MODE=false

# Firebase (agar ishlatilsa)
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# ...
